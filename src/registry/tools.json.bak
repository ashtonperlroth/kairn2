    "env_vars": [
      {
        "name": "SUPABASE_URL",
        "description": "Your Supabase project URL"
      },
      {
        "name": "SUPABASE_SERVICE_ROLE_KEY",
        "description": "Service role key (Settings > API)"
      }
    ],
    "signup_url": "https://supabase.com/dashboard"
  },
