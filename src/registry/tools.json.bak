    "auth": "none",
    "best_for": [
      "web-dev",
      "testing",
      "frontend",
      "e2e-testing"
    ],
    "install": {
      "plugin_command": "/plugin install playwright@claude-plugins-official"
    }
  },
  {
    "id": "semgrep",
    "name": "Semgrep",
    "description": "Static security analysis for finding vulnerabilities in code.",
    "category": "security",
    "tier": 2,
    "type": "mcp_server",
    "auth": "api_key",
    "best_for": [
      "coding",
      "security",
      "code-review"
    ],
    "install": {
      "mcp_config": {
        "semgrep": {
          "command": "npx",
          "args": [
            "-y",
            "@semgrep/mcp"
          ],
          "env": {
            "SEMGREP_APP_TOKEN": "${SEMGREP_APP_TOKEN}"
          }
        }
      }
    },
    "env_vars": [
      {
        "name": "SEMGREP_APP_TOKEN",
        "description": "Semgrep app token for static analysis"
      }
    ],
    "signup_url": "https://semgrep.dev/login"
  },
