  {
    "id": "github",
    "name": "GitHub",
    "description": "PR management, code search, issue tracking, and commit operations.",
    "category": "code_devtools",
    "tier": 2,
    "type": "mcp_server",
    "auth": "oauth",
    "best_for": [
      "coding",
      "collaboration",
      "open-source",
      "github"
    ],
    "install": {
      "mcp_config": {
        "github": {
          "command": "npx",
          "args": [
            "-y",
            "@anthropic/mcp-server-github"
          ],
          "env": {
            "GITHUB_TOKEN": "${GITHUB_TOKEN}"
          }
        }
      }
    },
    "env_vars": [
      {
        "name": "GITHUB_TOKEN",
        "description": "Personal access token (Settings > Developer settings > Tokens)"
      }
    ],
    "signup_url": "https://github.com/settings/tokens"
  },
  {
    "id": "playwright",
    "name": "Playwright",
    "description": "Browser control for testing UIs, taking screenshots, and web automation.",
