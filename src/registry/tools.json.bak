[
  {
    "id": "context7",
    "name": "Context7",
    "description": "Live, version-specific library documentation lookup. Eliminates doc hallucination.",
    "category": "search_research",
    "tier": 1,
    "type": "mcp_server",
    "auth": "none",
    "best_for": [
      "coding",
      "library-usage",
      "documentation",
      "any"
    ],
    "install": {
      "mcp_config": {
        "context7": {
          "command": "npx",
          "args": [
            "-y",
            "@upstash/context7-mcp@latest"
          ]
        }
      }
    }
  },
  {
    "id": "sequential-thinking",
