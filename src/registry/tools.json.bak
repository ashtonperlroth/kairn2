  {
    "id": "postgres",
    "name": "PostgreSQL (Bytebase)",
    "description": "Natural language SQL queries against PostgreSQL databases.",
    "category": "data_infrastructure",
    "tier": 4,
    "type": "mcp_server",
    "auth": "connection_string",
    "best_for": [
      "database",
      "data-analysis",
      "backend",
      "sql"
    ],
    "install": {
      "mcp_config": {
        "postgres": {
          "command": "npx",
          "args": [
            "-y",
            "@bytebase/dbhub",
            "--dsn",
            "${DATABASE_URL}"
          ]
        }
      }
    },
    "env_vars": [
      {
        "name": "DATABASE_URL",
        "description": "PostgreSQL connection string (postgres://user:pass@host:5432/db)"
      }
    ]
  },
  {
    "id": "supabase",
    "name": "Supabase",
    "description": "Production Postgres with row-level security and auth management.",
    "category": "data_infrastructure",
    "tier": 4,
    "type": "mcp_server",
    "auth": "api_key",
    "best_for": [
      "backend",
